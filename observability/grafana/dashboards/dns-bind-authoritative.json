{
  "uid": "dns-bind-authoritative",
  "title": "Authoritative Stats",
  "tags": ["dns", "bind"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "links": [
    {
      "type": "link",
      "title": "Kibana Logs (Authoritative Parent)",
      "url": "http://localhost:5601/app/discover#/?_g=(time:(from:'${__from:date:iso}',to:'${__to:date:iso}'))&_a=(query:(language:kuery,query:'role:authoritative_parent'))",
      "targetBlank": true
    },
    {
      "type": "link",
      "title": "Kibana Logs (Authoritative Child)",
      "url": "http://localhost:5601/app/discover#/?_g=(time:(from:'${__from:date:iso}',to:'${__to:date:iso}'))&_a=(query:(language:kuery,query:'role:authoritative_child'))",
      "targetBlank": true
    }
  ],
  "panels": [
    {
      "id": 20,
      "type": "timeseries",
      "title": "Authoritative Queries per Second",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "decimals": 2 },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (server) (rate(bind_queries_total[5m]))",
          "legendFormat": "{{server}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Response Codes",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "decimals": 2 },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (server, rcode) (rate(bind_rcode_total[5m]))",
          "legendFormat": "{{server}} {{rcode}}",
          "refId": "A"
        }
      ]
    }
  ]
}
