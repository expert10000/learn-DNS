$TTL 300
@   IN SOA ns1.test. admin.test. (
        2026022801 ; serial
        1h         ; refresh
        15m        ; retry
        1w         ; expire
        5m         ; negative caching
)
    IN NS  ns1.test.
    IN NSEC3PARAM 1 0 10 A1B2

ns1 IN A   172.31.0.10

; Delegate example.test to the child authoritative.
example  IN NS  ns-child.test.
example  IN DS  3984 13 2 5BB8FBCB7C4EDD860A574141A050D575F538D76C8FC96A7D7057191E51F1C70B

; Authoritative NS name for the child (in parent zone, signed).
ns-child IN A 172.31.0.11
