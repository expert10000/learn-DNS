$TTL 300
@   IN SOA ns-child.test. admin.example.test. (
        2026030203 ; serial
        1h         ; refresh
        15m        ; retry
        1w         ; expire
        5m         ; negative caching
)
    IN NS  ns-child.test.
    IN NSEC3PARAM 1 0 10 A1B2
    IN MX 10 mail.example.test.

ns1 IN A   172.31.0.11
www IN A   172.31.0.11
mail IN A  172.32.0.25

; ===== SPF (TXT dla domeny) =====
@   IN TXT "v=spf1 ip4:172.32.0.25 -all"

; (opcjonalnie) SPF dla subdomeny "mail"
mail IN TXT "v=spf1 ip4:172.32.0.25 -all"

; ===== DKIM (TXT pod selektorem) =====
