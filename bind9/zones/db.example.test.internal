$TTL 300
@   IN SOA ns-child.test. admin.example.test. (
        2026022801 ; serial
        1h         ; refresh
        15m        ; retry
        1w         ; expire
        5m         ; negative caching
)
    IN NS  ns-child.test.
    IN NSEC3PARAM 1 0 10 A1B2

ns1 IN A   172.31.0.11
www IN A   10.10.0.10
app IN A   10.10.0.20
